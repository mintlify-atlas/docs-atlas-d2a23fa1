  "keyFeatures": [
    "Role-based access control with JWT authentication",
    "Comprehensive inventory and product management with categories and variants",
    "Efficient POS workflow with cart system and order processing",
    "Digital payment integration via Midtrans Payment Gateway",
    "Cloud storage integration with Cloudflare R2 for product images",
    "Real-time dashboard with sales analytics and reports",
    "Complete audit trails with activity logging",
    "Multi-language support (English/Indonesian)",
    "Receipt generation and ESC/POS printer integration",
    "Shift management for cashier operations"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/login - User authentication",
    "POST /api/v1/auth/register - User registration",
    "POST /api/v1/auth/logout - User logout",
    "GET /api/v1/products - List products with pagination",
    "POST /api/v1/products - Create new product",
    "PUT /api/v1/products/:id - Update product",
    "DELETE /api/v1/products/:id - Delete product",
    "GET /api/v1/categories - List categories",
    "POST /api/v1/orders - Create new order",
    "PUT /api/v1/orders/:id - Update order status",
    "POST /api/v1/orders/:id/payment - Process payment",
    "GET /api/v1/transactions - List transactions with filters",
    "GET /api/v1/reports/sales - Sales reports",
    "GET /api/v1/reports/cashier-performance - Cashier performance metrics",
    "GET /api/v1/reports/popular-products - Popular products analysis",
    "GET /api/v1/activity-logs - Activity logs with pagination",
    "GET /api/v1/users - List users (admin only)",
    "POST /api/v1/users - Create user (admin only)",
    "GET /api/v1/promotions - List active promotions",
    "POST /api/v1/promotions - Create promotion",
    "GET /api/v1/payment-methods - List payment methods",
    "GET /api/v1/settings - Get system settings",
    "PUT /api/v1/settings - Update system settings",
    "GET /api/v1/shifts - List shifts",
    "POST /api/v1/shifts/start - Start new shift",
    "POST /api/v1/shifts/end - End current shift"
  ]
}
